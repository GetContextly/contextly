{
  "name": "contextly",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test -w packages/shared && npm run test -w packages/cli && npm run test -w packages/mcp-server",
    "test:shared": "npm run test -w packages/shared",
    "test:cli": "npm run test -w packages/cli",
    "test:mcp": "npm run test -w packages/mcp-server",
    "build": "npm run build -w packages/shared && npm run build -w packages/cli && npm run build -w packages/mcp-server",
    "build:shared": "npm run build -w packages/shared",
    "build:cli": "npm run build -w packages/cli",
    "build:mcp": "npm run build -w packages/mcp-server",
    "supabase:login": "supabase login",
    "supabase:init": "supabase init",
    "supabase:migration": "supabase migration new",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push",
    "vercel:login": "vercel login",
    "vercel:deploy": "vercel deploy --prefix packages/dashboard",
    "render:login": "render login"
  }
}
