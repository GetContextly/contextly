# Copy this file to .env and fill in real values. Never commit the filled-in .env file.
# See docs/ENVIRONMENT_SETUP.md for where each value comes from.

# --- Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-signing-secret

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# --- MCP Server ---
MCP_SERVER_PORT=7420
MCP_SERVER_PUBLIC_URL=http://localhost:7420

# --- Dashboard ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_APP_NAME=contextly-dev

# --- Email (optional) ---
RESEND_API_KEY=re_...

# --- General ---
NODE_ENV=development
